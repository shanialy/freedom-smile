      {
        "title": "Hábitos Diarios de Cepillado",
        "description": "Cepille sus dientes dos veces al día con pasta dental con flúor para prevenir las caries y mantener las encías saludables."
      },
      {
        "title": "Revisiones Dentales Regulares",
        "description": "Visite a su dentista cada seis meses para una limpieza profesional y la detección temprana de problemas bucales."
      },
      {
        "title": "Alimentación Saludable",
        "description": "Reduzca los alimentos y bebidas azucaradas. Consuma frutas, verduras y alimentos ricos en calcio."
      },
      {
        "title": "Use Hilo Dental Todos los Días",
        "description": "El hilo dental elimina la placa y los restos de comida donde el cepillo no puede llegar."
      },
      {
        "title": "Beba Más Agua",
        "description": "El agua ayuda a eliminar los restos de comida y mantiene la boca hidratada."
      },
      {
        "title": "Proteja Sus Dientes",
        "description": "Use un protector bucal al practicar deportes para reducir el riesgo de lesiones dentales."
      },
      {
        "title": "Evite Fumar",
        "description": "Fumar puede manchar los dientes, dañar las encías y aumentar el riesgo de cáncer oral."
      },
      {
        "title": "Cambie el Cepillo de Dientes",
        "description": "Cambie su cepillo de dientes cada tres meses o antes si las cerdas están desgastadas."
      }
    ],

